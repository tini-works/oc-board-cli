{
  "name": "prev-cli",
  "version": "0.24.19",
  "description": "Transform MDX directories into beautiful documentation websites",
  "type": "module",
  "license": "MIT",
  "bin": {
    "prev": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src/theme",
    "src/ui",
    "src/preview-runtime",
    "src/jsx",
    "src/primitives",
    "src/tokens"
  ],
  "keywords": [
    "documentation",
    "mdx",
    "markdown",
    "cli",
    "static-site",
    "vite",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lagz0ne/prev-cli.git"
  },
  "bugs": {
    "url": "https://github.com/lagz0ne/prev-cli/issues"
  },
  "homepage": "https://github.com/lagz0ne/prev-cli#readme",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target bun --packages external --banner 'if(typeof globalThis.Bun===\"undefined\"){console.error(\"\\n\\x1b[31mError: prev-cli requires Bun runtime\\x1b[0m\\n\\nYou are running with Node.js, but prev-cli uses Bun-specific APIs.\\n\\n\\x1b[33mTo install and run with Bun:\\x1b[0m\\n\\n  # Global install (recommended)\\n  bun i -g prev-cli\\n  prev-cli dev\\n\\n  # Or local install\\n  bun add -d prev-cli\\n  bunx --bun prev-cli dev\\n\\n\\x1b[90mLearn more: https://bun.sh/docs/installation\\x1b[0m\\n\");process.exit(1)}' && tsc --emitDeclarationOnly",
    "build:docs": "bun run build && bun ./dist/cli.js build",
    "prepublishOnly": "bun run build",
    "dev": "tsc --watch",
    "test": "bun test src",
    "test:integration": "bun run build && bun test test/integration.test.ts",
    "test:all": "bun run test && bun run test:integration"
  },
  "dependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript/native-preview": "^7.0.0-dev",
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-router": "^1.145.7",
    "@terrastruct/d2": "^0.1.33",
    "@vitejs/plugin-react": "^5.1.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "esbuild": "^0.27.2",
    "fast-glob": "^3.3.0",
    "fumadocs-core": "^16.4.3",
    "fumadocs-ui": "^16.4.3",
    "js-yaml": "^4.1.1",
    "mermaid": "^11.0.0",
    "picomatch": "^4.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.5.0",
    "tailwindcss": "3",
    "vite": "npm:rolldown-vite@^7.3.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^22.0.0",
    "@types/picomatch": "^4.0.2",
    "bun-types": "^1.3.5",
    "typescript": "^5.7.0"
  }
}
